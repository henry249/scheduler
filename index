function applyRhythm(){
  const month=document.getElementById('rhythm-month').value;
  const freq=parseInt(document.getElementById('rhythm-freq').value);
  const ownersRaw=document.getElementById('rhythm-owners').value.trim();
  const owners=ownersRaw?ownersRaw.split(/[,，]\s*/):[''];
  const [y,m]=month.split('-').map(Number);
  const dim=new Date(y,m,0).getDate();
  // pick weekday targets based on freq
  const targetDays=freq===2?[1,4]:freq===3?[1,3,5]:freq===4?[1,2,4,5]:[1,2,3,4,5];
  // build sequence of types from ratio
  const typeSeq=[];
  MONTH_RATIO.forEach(r=>{for(let i=0;i<r.count;i++)typeSeq.push(r.type);});
  // shuffle lightly to mix
  for(let i=typeSeq.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[typeSeq[i],typeSeq[j]]=[typeSeq[j],typeSeq[i]];}
  const types=getTypes();
  const newPosts=[];
  let typeIdx=0,ownerIdx=0;
  for(let d=1;d<=dim;d++){
    const date=new Date(y,m-1,d);
    if(targetDays.includes(date.getDay())){
      const typeId=typeSeq[typeIdx%typeSeq.length];
      const typeName=types[typeId]||'內容';
      newPosts.push({
        id:Date.now()+d+Math.random(),
        date:`${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`,
        dateEnd:'',time:'10:00',
        platform:'Facebook + Instagram',
        type:typeId,
        title:`【${typeName}】待填寫標題`,
        note:`本篇類型：${typeName}。請根據當週主題填寫實際標題與內容。`,
        owner:owners[ownerIdx%owners.length],
        status:'待撰寫',colorBg:'',colorText:''
      });
      typeIdx++;ownerIdx++;
    }
  }
  if(!newPosts.length){toast('該月份找不到符合的日期');return;}
  posts.push(...newPosts);
  posts.sort((a,b)=>(a.date+a.time).localeCompare(b.date+b.time));
  save();
  document.getElementById('rhythm-preview').innerHTML=`<div style="background:var(--accent-bg);border:1px solid #A0C8A8;border-radius:var(--r);padding:10px 14px;font-size:13px;color:var(--accent-text)">✅ 已加入 ${newPosts.length} 則框架排程到 ${y}年${m}月，請到月曆或排程總表填入實際標題！</div>`;
  toast(`已套用節奏框架，加入 ${newPosts.length} 則`);
}

