<script>
// ══ Default Types (can be customised) ══
const DEFAULT_TYPES=[
  {id:'1',name:'檔期活動',bg:'#EEEDFE',text:'#3C3489'},
  {id:'2',name:'專欄文章',bg:'#E1F5EE',text:'#085041'},
  {id:'3',name:'檔期主推品項',bg:'#FAEEDA',text:'#633806'},
  {id:'4',name:'閱讀器',bg:'#E6F1FB',text:'#0C447C'},
  {id:'5',name:'非閱讀器',bg:'#EAF3DE',text:'#27500A'},
  {id:'6',name:'特殊節日',bg:'#FBEAF0',text:'#72243E'},
  {id:'7',name:'即時話題',bg:'#FAECE7',text:'#712B13'},
];

// Dynamic types loaded from localStorage
let customTypes=JSON.parse(localStorage.getItem('sched_types')||'null')||DEFAULT_TYPES;
// Campaigns
let campaigns=JSON.parse(localStorage.getItem('sched_campaigns')||'[]');

function saveTypes(){localStorage.setItem('sched_types',JSON.stringify(customTypes));}
function saveCampaigns(){localStorage.setItem('sched_campaigns',JSON.stringify(campaigns));}

// Derived helpers (rebuild whenever types change)
function getTypes(){return Object.fromEntries(customTypes.map(t=>[t.id,t.name]))}
function getTColors(){return Object.fromEntries(customTypes.map(t=>[t.id,{bg:t.bg,text:t.text}]))}
function TYPES(){return getTypes()}
// shim: badge css class falls back to inline style; TCLS only used for legacy badge class
function typeBadgeStyle(typeId){const c=getTColors()[typeId]||{bg:'#F0EDE8',text:'#6B6459'};return`background:${c.bg};color:${c.text}`;}

const STATUSES=['待撰寫','撰寫中','待審核','已排程','已發佈'];
const SCLS=['s0','s1','s2','s3','s4'];

// ══ Color Palette ══
const COLOR_PALETTE=[
  {bg:'#EEEDFE',text:'#3C3489',label:'紫'},{bg:'#E1F5EE',text:'#085041',label:'綠'},
  {bg:'#FAEEDA',text:'#633806',label:'橙'},{bg:'#E6F1FB',text:'#0C447C',label:'藍'},
  {bg:'#EAF3DE',text:'#27500A',label:'草綠'},{bg:'#FBEAF0',text:'#72243E',label:'粉'},
  {bg:'#FAECE7',text:'#712B13',label:'橘紅'},{bg:'#FDE8E8',text:'#8B1A1A',label:'紅'},
  {bg:'#FFF3CD',text:'#856404',label:'黃'},{bg:'#E0F4FF',text:'#0369A1',label:'水藍'},
  {bg:'#F0F0F0',text:'#3A3A3A',label:'灰'},{bg:'#1A1714',text:'#F5F3EE',label:'黑'},
];

function getPostColor(p){
  if(p.colorBg&&p.colorText)return{bg:p.colorBg,text:p.colorText};
  const tc=getTColors();
  return tc[p.type]||{bg:'#F0EDE8',text:'#6B6459'};
}

function buildColorPicker(rowId,hidBgId,hidTextId,currentBg,currentText){
  const row=document.getElementById(rowId);if(!row)return;
  let html='';
  COLOR_PALETTE.forEach(c=>{
    const isActive=currentBg===c.bg;
    html+=`<div class="color-swatch${isActive?' active':''}" style="background:${c.bg};border-color:${isActive?c.text:'transparent'}" title="${c.label}" onclick="pickColor('${rowId}','${hidBgId}','${hidTextId}','${c.bg}','${c.text}',this)"></div>`;
  });
  html+=`<div class="color-custom" title="自訂顏色"><input type="color" value="${currentBg||'#E0F4FF'}" oninput="pickCustomColor('${rowId}','${hidBgId}','${hidTextId}',this.value)"><span style="font-size:12px;pointer-events:none">＋</span></div>`;
  row.innerHTML=html;
  document.getElementById(hidBgId).value=currentBg||'';
  document.getElementById(hidTextId).value=currentText||'';
}
function pickColor(rowId,hidBgId,hidTextId,bg,text,el){
  document.getElementById(hidBgId).value=bg;document.getElementById(hidTextId).value=text;
  document.querySelectorAll(`#${rowId} .color-swatch`).forEach(s=>s.classList.remove('active'));
  el.classList.add('active');el.style.borderColor=text;
}
function pickCustomColor(rowId,hidBgId,hidTextId,bg){
  document.getElementById(hidBgId).value=bg;
  const r=parseInt(bg.slice(1,3),16),g=parseInt(bg.slice(3,5),16),b=parseInt(bg.slice(5,7),16);
  const lum=0.299*r+0.587*g+0.114*b;
  document.getElementById(hidTextId).value=lum>160?'#1A1714':'#F5F3EE';
  document.querySelectorAll(`#${rowId} .color-swatch`).forEach(s=>s.classList.remove('active'));
}

// ══ Settings: Types ══
function renderTypeList(){
  const el=document.getElementById('type-list');if(!el)return;
  el.innerHTML=customTypes.map((t,i)=>`
    <div class="type-item">
      <div class="type-color-dot" style="background:${t.bg};border:1px solid ${t.text}60"></div>
      <div class="type-item-name">${esc(t.name)}</div>
      ${customTypes.length>1?`<button class="btn btn-danger btn-sm" onclick="deleteType('${t.id}')">刪除</button>`:''}
    </div>`).join('');
}
function addType(){
  const name=document.getElementById('new-type-name').value.trim();
  const bg=document.getElementById('new-type-color').value;
  if(!name){toast('請填寫類型名稱');return;}
  const r=parseInt(bg.slice(1,3),16),g=parseInt(bg.slice(3,5),16),b=parseInt(bg.slice(5,7),16);
  const lum=0.299*r+0.587*g+0.114*b;
  const text=lum>160?'#1A1714':'#F5F3EE';
  // lighten bg for readability
  const lightBg=`rgba(${r},${g},${b},0.18)`;
  const id='t'+Date.now();
  customTypes.push({id,name,bg:lightBg,text:bg});
  saveTypes();
  document.getElementById('new-type-name').value='';
  renderTypeList();refreshTypeSelects();toast('已新增類型：'+name);
}
function deleteType(id){
  if(posts.some(p=>p.type===id)){toast('此類型已有發文，請先修改發文後再刪除');return;}
  customTypes=customTypes.filter(t=>t.id!==id);
  saveTypes();renderTypeList();refreshTypeSelects();toast('已刪除');
}
function refreshTypeSelects(){
  const types=getTypes();
  const opts=customTypes.map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  const filterOpts='<option value="">全部類型</option>'+opts;
  ['f-type'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML=opts;});
  ['fil-type'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML=filterOpts;});
  // AI system prompt type list rebuilt dynamically in runAI
}

// ══ Settings: Campaigns ══
function renderCampaignList(){
  const el=document.getElementById('campaign-list');if(!el)return;
  if(!campaigns.length){el.innerHTML='<div style="font-size:12.5px;color:var(--text3);padding:8px 0">尚無檔期，請新增</div>';return;}
  el.innerHTML=campaigns.map((c,i)=>`
    <div class="camp-item">
      <div class="camp-dot" style="background:${c.color}80;border:1px solid ${c.color}"></div>
      <div class="camp-info">
        <div class="camp-name">${esc(c.name)}</div>
        <div class="camp-dates">${c.start} → ${c.end}</div>
      </div>
      <button class="btn btn-danger btn-sm" onclick="deleteCampaign(${i})">刪除</button>
    </div>`).join('');
}
function addCampaign(){
  const name=document.getElementById('new-camp-name').value.trim();
  const start=document.getElementById('new-camp-start').value;
  const end=document.getElementById('new-camp-end').value;
  const color=document.getElementById('new-camp-color').value;
  if(!name||!start||!end){toast('請填寫檔期名稱與起訖日期');return;}
  if(start>end){toast('起始日期必須早於結束日期');return;}
  campaigns.push({name,start,end,color});
  saveCampaigns();
  ['new-camp-name','new-camp-start','new-camp-end'].forEach(id=>document.getElementById(id).value='');
  renderCampaignList();toast('已新增檔期：'+name);
}
function deleteCampaign(i){campaigns.splice(i,1);saveCampaigns();renderCampaignList();toast('已刪除檔期');}

