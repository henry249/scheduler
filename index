<nav>
  <button class="ntab active" onclick="showPage('cal')">📅 月曆</button>
  <button class="ntab" onclick="showPage('gantt')">📊 甘特圖</button>
  <button class="ntab" onclick="showPage('list')">📋 排程總表</button>
  <button class="ntab" onclick="showPage('add')">＋ 新增發文</button>
  <button class="ntab" onclick="showPage('ai')">✨ AI 排程</button>
