function addAIResults(){
  const toAdd=aiResults.filter((_,i)=>document.getElementById('ai-item-'+i)?.classList.contains('selected'));
  if(!toAdd.length){toast('請至少選取一則');return;}
  toAdd.forEach(p=>posts.push({id:Date.now()+Math.random(),date:p.date,dateEnd:'',time:p.time,platform:p.platform,type:p.type,title:p.title,note:p.note,owner:p.owner||'',status:p.status||'待撰寫',colorBg:'',colorText:''}));
  posts.sort((a,b)=>(a.date+a.time).localeCompare(b.date+b.time));
  save();aiResults=[];
  document.getElementById('ai-result-area').innerHTML='';
  document.getElementById('ai-add-row').style.display='none';
  toast(`✅ 已加入 ${toAdd.length} 則排程！`);showPage('cal');
}

// ══ Export ══
function buildExport(fmt){
  const types=getTypes();
  const headers=['日期','迄日','時間','平台','內容類型','主題/標題','說明','負責人','狀態'];
  const rows=posts.map(p=>[p.date,p.dateEnd||'',p.time,p.platform,types[p.type]||p.type,p.title,p.note,p.owner,p.status]);
  let out='';
  if(fmt==='tsv')out=[headers,...rows].map(r=>r.join('\t')).join('\n');
  else{const sep=headers.map(()=>'---');out=[headers,sep,...rows].map(r=>'| '+r.join(' | ')+' |').join('\n')}
  document.getElementById('copy-out').value=out||'（尚無資料）';
}
function copyOut(){const el=document.getElementById('copy-out');el.select();document.execCommand('copy');toast('已複製！')}

function backupJSON(){
  const data={posts,customTypes,campaigns,exportedAt:new Date().toISOString()};
  const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='scheduler-backup-'+new Date().toISOString().slice(0,10)+'.json';
  a.click();
  toast('已下載備份檔！');
}
function restoreJSON(e){
  const file=e.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    try{
      const data=JSON.parse(ev.target.result);
      if(data.posts)posts=data.posts;
      if(data.customTypes)customTypes=data.customTypes;
      if(data.campaigns)campaigns=data.campaigns;
      save();saveTypes();saveCampaigns();
      refreshTypeSelects();renderAll();
      toast('✅ 資料已還原！共 '+posts.length+' 則發文');
    }catch{toast('❌ 檔案格式錯誤，請選擇正確的備份檔');}
  };
  reader.readAsText(file);
  e.target.value='';
}

// ══ Quick-add modal ══
function openQA(date){
  const el=document.getElementById('qa-modal-bg');
  document.getElementById('qa-date').value=date||'';
  document.getElementById('qa-date-end').value='';
  document.getElementById('qa-time').value='10:00';
  document.getElementById('qa-title').value='';
  document.getElementById('qa-note').value='';
  document.getElementById('qa-owner').value='';
  document.getElementById('qa-status').value='待撰寫';
  document.getElementById('qa-date-badge').textContent=date?formatDateTW(date):'';
  // populate type select dynamically
  document.getElementById('qa-type').innerHTML=customTypes.map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  el.classList.add('open');
  setTimeout(()=>document.getElementById('qa-title').focus(),200);
}
function closeQA(e){if(e.target===document.getElementById('qa-modal-bg'))closeQADirect();}
function closeQADirect(){document.getElementById('qa-modal-bg').classList.remove('open');}
function submitQA(){
  const date=document.getElementById('qa-date').value;
  const title=document.getElementById('qa-title').value.trim();
  if(!date){toast('請選擇日期');return;}
  if(!title){toast('請填寫標題');return;}
  posts.push({
    id:Date.now(),
    date,
    dateEnd:document.getElementById('qa-date-end').value,
    time:document.getElementById('qa-time').value,
    platform:document.getElementById('qa-platform').value,
    type:document.getElementById('qa-type').value,
    title,
    note:document.getElementById('qa-note').value.trim(),
    owner:document.getElementById('qa-owner').value.trim(),
    status:document.getElementById('qa-status').value,
    colorBg:'',colorText:''
  });
  posts.sort((a,b)=>(a.date+a.time).localeCompare(b.date+b.time));
  save();closeQADirect();
  renderCal();renderGantt();
  toast('已新增！');
}
function formatDateTW(ds){
  const[y,m,d]=ds.split('-');
  return `${y}年${parseInt(m)}月${parseInt(d)}日`;
}

// ══ Utils ══
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function renderAll(){renderCal();renderGantt();renderList()}

// ══ Init ══
save();
refreshTypeSelects();
renderCal();
buildColorPicker('f-color-row','f-color-bg','f-color-text','','');
if(localStorage.getItem('ai_key'))document.getElementById('ai-key').value=localStorage.getItem('ai_key');
</script>
