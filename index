function renderCal(){
  document.getElementById('cal-ym').textContent=calYear+'年 '+(calMonth+1)+'月';
  const showHd=document.getElementById('show-hdays').checked;
  const today=new Date();
  const firstDay=new Date(calYear,calMonth,1).getDay();
  const dim=new Date(calYear,calMonth+1,0).getDate();
  const dimp=new Date(calYear,calMonth,0).getDate();
  const usedTypes=[...new Set(posts.filter(p=>{const[y,m]=p.date.split('-').map(Number);return y===calYear&&m-1===calMonth}).map(p=>p.type))];
  document.getElementById('cal-legend').innerHTML=usedTypes.map(t=>`<div class="leg-item"><div class="leg-dot" style="background:${TCOLORS[t].bg};border:1px solid ${TCOLORS[t].text}50"></div>${TYPES[t]}</div>`).join('');

  const container=document.getElementById('cal-days');
  container.innerHTML='';

  // prev filler
  for(let i=0;i<firstDay;i++){
    const cell=document.createElement('div');
    cell.className='cal-day other-m';
    cell.innerHTML=`<div class="dn">${dimp-firstDay+1+i}</div>`;
    container.appendChild(cell);
  }

  // current month cells
  for(let d=1;d<=dim;d++){
    const ds=calYear+'-'+String(calMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const dp=posts.filter(p=>p.date===ds||rangeIncludes(p,ds)).sort((a,b)=>a.time.localeCompare(b.time));
    const hdayForDay=showHd?HOLIDAYS.filter(h=>h.date===ds):[];
    const isT=today.getFullYear()===calYear&&today.getMonth()===calMonth&&today.getDate()===d;

    const cell=document.createElement('div');
    cell.className='cal-day'+(isT?' today':'');
    cell.dataset.date=ds;
    cell.title='點擊空白處新增發文';
    // click on cell background = quick add
    cell.addEventListener('click',e=>{
      if(e.target===cell||e.target.classList.contains('dn')||e.target.classList.contains('cal-events')){
        openQA(ds);
      }
    });

    // dragover target
    cell.addEventListener('dragover',e=>{e.preventDefault();cell.style.background='#E6EFE9';});
    cell.addEventListener('dragleave',()=>{cell.style.background='';});
    cell.addEventListener('drop',e=>{
      e.preventDefault();cell.style.background='';
      const pid=parseInt(e.dataTransfer.getData('postId'));
      const p=posts.find(x=>x.id===pid);
      if(!p)return;
      // shift dateEnd if range
      if(p.dateEnd){
        const diff=(new Date(ds)-new Date(p.date))/(86400000);
        const newEnd=new Date(new Date(p.dateEnd).getTime()+diff*86400000);
        p.dateEnd=newEnd.toISOString().slice(0,10);
      }
      p.date=ds;
      posts.sort((a,b)=>(a.date+a.time).localeCompare(b.date+b.time));
      save();renderCal();toast('已移至 '+ds);
    });

    // day number
    const numEl=document.createElement('div');
    numEl.className='dn';
    if(isT){
      numEl.innerHTML=`<div style="background:var(--accent);color:#fff;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:500;font-size:12px">${d}</div>`;
    } else {
      numEl.textContent=d;
    }
    cell.appendChild(numEl);

    // holidays
    const evEl=document.createElement('div');
    evEl.className='cal-events';
    hdayForDay.forEach(h=>{
      const hEl=document.createElement('div');
      hEl.className='cal-hday';
      hEl.style.cssText=`background:${h.color};color:${h.textColor}`;
      hEl.title=h.name;hEl.textContent=h.name;
      evEl.appendChild(hEl);
    });

    const MAX=3;
    dp.slice(0,MAX).forEach(p=>{
      const col=getPostColor(p);
      const ev=document.createElement('div');
      ev.className='cal-ev';
      ev.style.cssText=`background:${col.bg};color:${col.text};cursor:grab`;
      ev.title=p.title;
      ev.textContent=(p.time?p.time.slice(0,5)+' ':'')+p.title;
      ev.draggable=true;
      ev.addEventListener('dragstart',e=>{
        e.dataTransfer.setData('postId',p.id);
        ev.style.opacity='.4';
      });
      ev.addEventListener('dragend',()=>{ev.style.opacity='';});
      ev.addEventListener('click',e=>{
        if(!e.defaultPrevented)openModal(ds,null);
      });
      evEl.appendChild(ev);
    });

    if(dp.length>MAX){
      const more=document.createElement('div');
      more.className='more-lnk';
      more.textContent=`+${dp.length-MAX} 則`;
      more.onclick=()=>openModal(ds,null);
      evEl.appendChild(more);
    }
    cell.appendChild(evEl);
    container.appendChild(cell);
  }

  // next filler
  const tot=firstDay+dim;const rem=(7-tot%7)%7;
  for(let d=1;d<=rem;d++){
    const cell=document.createElement('div');
    cell.className='cal-day other-m';
    cell.innerHTML=`<div class="dn">${d}</div>`;
    container.appendChild(cell);
  }
}
function rangeIncludes(p,ds){if(!p.dateEnd)return false;return ds>=p.date&&ds<=p.dateEnd}

