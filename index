<!-- ══ 月曆 ══ -->
<div class="page active" id="page-cal">
  <div class="cal-hd">
    <div class="cal-nav">
      <button class="cal-btn" onclick="chMonth(-1)">‹</button>
      <button class="cal-btn" onclick="chMonth(1)">›</button>
      <div class="cal-ym" id="cal-ym"></div>
      <button class="today-btn" onclick="goToday()">今天</button>
    </div>
    <label style="font-size:12px;color:var(--text2);display:flex;align-items:center;gap:6px;cursor:pointer">
      <input type="checkbox" id="show-hdays" checked onchange="renderCal()"> 顯示節日
    </label>
  </div>
  <div class="legend" id="cal-legend"></div>
  <div class="cal-grid">
    <div class="cal-dow">
      <div class="cal-dow-cell">日</div><div class="cal-dow-cell">一</div><div class="cal-dow-cell">二</div>
      <div class="cal-dow-cell">三</div><div class="cal-dow-cell">四</div><div class="cal-dow-cell">五</div><div class="cal-dow-cell">六</div>
    </div>
    <div class="cal-days" id="cal-days"></div>
  </div>
</div>

<!-- ══ 甘特圖 ══ -->
<div class="page" id="page-gantt">
  <div class="cal-hd">
    <div class="cal-nav">
      <button class="cal-btn" onclick="chGanttMonth(-1)">‹</button>
      <button class="cal-btn" onclick="chGanttMonth(1)">›</button>
      <div class="cal-ym" id="gantt-ym"></div>
      <button class="today-btn" onclick="goGanttToday()">今天</button>
    </div>
  </div>
  <div class="gantt-wrap"><div class="gantt-inner" id="gantt-inner"></div></div>
</div>

<!-- ══ 排程總表 ══ -->
<div class="page" id="page-list">
  <div class="filter-bar">
    <select id="fil-type" onchange="renderList()">
      <option value="">全部類型</option>
      <option value="1">檔期活動</option><option value="2">專欄文章</option><option value="3">檔期主推品項</option>
      <option value="4">閱讀器</option><option value="5">非閱讀器</option><option value="6">特殊節日</option><option value="7">即時話題</option>
    </select>
    <select id="fil-status" onchange="renderList()">
      <option value="">全部狀態</option>
      <option>待撰寫</option><option>撰寫中</option><option>待審核</option><option>已排程</option><option>已發佈</option>
    </select>
    <select id="fil-owner" onchange="renderList()"><option value="">全部負責人</option></select>
    <span class="pill" id="list-count">0 則</span>
  </div>
  <div class="table-wrap" id="list-table"></div>
</div>

<!-- ══ 新增發文 ══ -->
<div class="page" id="page-add">
  <div class="form-panel">
    <div class="fp-title">新增發文</div>
    <div class="fg">
      <div class="field"><label>發文日期（起）</label><input type="date" id="f-date"></div>
      <div class="field"><label>發文日期（迄，區段填）</label><input type="date" id="f-date-end"></div>
      <div class="field"><label>發文時間</label><input type="time" id="f-time" value="10:00"></div>
      <div class="field"><label>平台</label>
        <select id="f-platform"><option>Facebook</option><option>Instagram</option><option>Facebook + Instagram</option><option>Line</option><option>Threads</option><option>其他</option></select>
      </div>
      <div class="field"><label>內容類型</label>
        <select id="f-type"><option value="1">檔期活動</option><option value="2">專欄文章</option><option value="3">檔期主推品項</option><option value="4">閱讀器</option><option value="5">非閱讀器</option><option value="6">特殊節日</option><option value="7">即時話題</option></select>
      </div>
      <div class="field"><label>負責人</label><input type="text" id="f-owner" placeholder="姓名或暱稱"></div>
      <div class="field fg-full"><label>主題 / 標題</label><input type="text" id="f-title" placeholder="例：618 開跑！電子書最高 66 折"></div>
      <div class="field fg-full"><label>發文說明</label><textarea id="f-note" placeholder="說明要傳達什麼、用哪些素材、連結、hashtag 等"></textarea></div>
      <div class="field"><label>狀態</label>
        <select id="f-status"><option>待撰寫</option><option>撰寫中</option><option>待審核</option><option>已排程</option><option>已發佈</option></select>
      </div>
      <div class="field fg-full">
        <label>顏色標記（月曆與甘特圖顯示色）</label>
        <div class="color-picker-row" id="f-color-row"></div>
        <input type="hidden" id="f-color-bg" value="">
        <input type="hidden" id="f-color-text" value="">
      </div>
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="addPost()">＋ 新增至排程</button>
      <button class="btn btn-ghost" onclick="clearForm()">清空</button>
    </div>
  </div>
</div>

<!-- ══ AI 排程 ══ -->
<div class="page" id="page-ai">
  <div class="ai-panel">

    <!-- API Key -->
    <div style="display:flex;gap:8px;margin-bottom:1.25rem;align-items:center">
      <input type="password" id="ai-key" placeholder="Anthropic API Key（sk-ant-...）" style="flex:1;border:1px solid var(--border);border-radius:var(--r);padding:8px 11px;font-size:13px;font-family:var(--mono);background:var(--bg);color:var(--text);outline:none">
      <button class="btn btn-ghost btn-sm" onclick="saveKey()">儲存 Key</button>
    </div>

    <!-- 快速月份選擇 -->
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--rl);padding:1.25rem;margin-bottom:1rem">
      <div class="fp-title" style="margin-bottom:.75rem">🚀 快速規劃整月排程</div>

      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:1rem">
        <div class="field">
          <label>規劃月份</label>
          <select id="ai-month">
            <option value="2026-05">2026年 5月</option>
            <option value="2026-06">2026年 6月</option>
            <option value="2026-07">2026年 7月</option>
            <option value="2026-08">2026年 8月</option>
            <option value="2026-09">2026年 9月</option>
            <option value="2026-10">2026年 10月</option>
            <option value="2026-11">2026年 11月</option>
            <option value="2026-12">2026年 12月</option>
            <option value="2027-01">2027年 1月</option>
            <option value="2027-02">2027年 2月</option>
            <option value="2027-03">2027年 3月</option>
          </select>
        </div>
        <div class="field">
          <label>每週發文次數</label>
          <select id="ai-freq">
            <option value="2">每週 2 篇</option>
            <option value="3" selected>每週 3 篇</option>
            <option value="4">每週 4 篇</option>
            <option value="5">每週 5 篇</option>
            <option value="7">每天 1 篇</option>
          </select>
        </div>
        <div class="field">
          <label>主打平台</label>
          <select id="ai-platform">
            <option>Facebook + Instagram</option>
            <option>Facebook</option>
            <option>Instagram</option>
            <option>Threads</option>
          </select>
        </div>
      </div>

      <!-- 本月節日預覽 -->
      <div id="ai-hday-preview" style="margin-bottom:1rem"></div>

      <!-- 本月主力活動 -->
      <div class="field" style="margin-bottom:10px">
        <label>本月主力活動 / 檔期（選填）</label>
        <input type="text" id="ai-campaign" placeholder="例：618 周年慶、母親節、Kobo 新品上市">
      </div>

      <!-- 內容比重 -->
      <div class="field" style="margin-bottom:10px">
        <label>內容比重偏好（選填，不填 AI 自動分配）</label>
        <input type="text" id="ai-ratio" placeholder="例：閱讀器 3 篇、電子書優惠 4 篇、節日 2 篇、即時話題 2 篇">
      </div>

      <!-- 負責人 -->
      <div class="field" style="margin-bottom:1rem">
        <label>負責人（多人用逗號分隔，AI 會輪流分配）</label>
        <input type="text" id="ai-owners" placeholder="例：小美, 小強">
      </div>

      <button class="btn btn-primary" onclick="runSmartAI()" style="width:100%;justify-content:center">✨ AI 自動規劃整月排程</button>
    </div>

    <!-- 進階自訂 -->
    <details style="margin-bottom:1rem">
      <summary style="font-size:12.5px;color:var(--text2);cursor:pointer;padding:8px 0">▸ 進階：自行描述需求</summary>
      <div style="margin-top:10px">
        <div class="field" style="margin-bottom:10px">
          <label>自訂描述</label>
          <textarea id="ai-prompt" style="min-height:90px" placeholder="直接描述你的需求，AI 會根據 BearBoss 的品牌方向產生排程…"></textarea>
        </div>
        <button class="btn btn-primary" onclick="runAI()">✨ 產生排程</button>
      </div>
    </details>

    <div id="ai-result-area"></div>
    <div id="ai-add-row" style="display:none" class="btn-row">
      <button class="btn btn-primary" onclick="addAIResults()">✓ 加入已選排程</button>
      <button class="btn btn-ghost" onclick="selectAllAI()">全選</button>
      <button class="btn btn-ghost" onclick="deselectAllAI()">取消全選</button>
    </div>
  </div>
</div>
    <div id="ai-add-row" style="display:none" class="btn-row">
      <button class="btn btn-primary" onclick="addAIResults()">✓ 加入已選排程</button>
      <button class="btn btn-ghost" onclick="selectAllAI()">全選</button>
    </div>
  </div>
</div>

<!-- ══ 內容節奏 ══ -->
<div class="page" id="page-rhythm">
  <div style="max-width:900px">

    <!-- 週期框架 -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.5rem">
      <div class="form-panel" style="max-width:100%">
        <div class="fp-title">BearBoss 建議週發文節奏</div>
        <p style="font-size:12.5px;color:var(--text2);line-height:1.7;margin-bottom:1rem">根據閱讀器＋電子書的商品特性，建議以下週期安排：</p>
        <div id="rhythm-week"></div>
      </div>
      <div class="form-panel" style="max-width:100%">
        <div class="fp-title">月度內容配比建議</div>
        <p style="font-size:12.5px;color:var(--text2);line-height:1.7;margin-bottom:1rem">以每月 12 篇為基準的建議比重：</p>
        <div id="rhythm-ratio"></div>
      </div>
    </div>

    <!-- 套用節奏 -->
    <div class="form-panel" style="max-width:100%">
      <div class="fp-title">一鍵套用內容節奏框架</div>
      <p style="font-size:12.5px;color:var(--text2);line-height:1.7;margin-bottom:1rem">選擇月份和發文頻率，自動依照建議節奏產生排程框架（標題為模板，需再填入實際內容）。</p>
      <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end">
        <div class="field" style="margin-bottom:0;min-width:140px">
          <label>月份</label>
          <select id="rhythm-month">
            <option value="2026-05">2026年 5月</option>
            <option value="2026-06">2026年 6月</option>
            <option value="2026-07">2026年 7月</option>
            <option value="2026-08">2026年 8月</option>
            <option value="2026-09">2026年 9月</option>
            <option value="2026-10">2026年 10月</option>
            <option value="2026-11">2026年 11月</option>
            <option value="2026-12">2026年 12月</option>
          </select>
        </div>
        <div class="field" style="margin-bottom:0;min-width:130px">
          <label>每週篇數</label>
          <select id="rhythm-freq">
            <option value="2">每週 2 篇</option>
            <option value="3" selected>每週 3 篇</option>
            <option value="4">每週 4 篇</option>
          </select>
        </div>
        <div class="field" style="margin-bottom:0;min-width:140px">
          <label>負責人（逗號分隔）</label>
          <input type="text" id="rhythm-owners" placeholder="小美, 小強">
        </div>
        <button class="btn btn-primary" onclick="applyRhythm()">套用框架到排程</button>
      </div>
      <div id="rhythm-preview" style="margin-top:1rem"></div>
    </div>
  </div>
</div>

<!-- ══ 節日總覽 ══ -->
<div class="page" id="page-holiday">
  <div class="hday-filters" id="hday-filters">
    <span style="font-size:12px;color:var(--text2);font-weight:500">篩選：</span>
  </div>
  <div id="hday-list"></div>
</div>

<!-- ══ 設定 ══ -->
<div class="page" id="page-settings">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;max-width:900px">

    <!-- 內容類型管理 -->
    <div class="form-panel">
      <div class="fp-title">內容類型管理</div>
      <p style="font-size:12.5px;color:var(--text2);margin-bottom:1rem;line-height:1.6">新增或刪除內容類型，全站（月曆、甘特圖、篩選）即時同步。</p>
      <div id="type-list"></div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <input type="text" id="new-type-name" placeholder="新類型名稱" style="flex:1;border:1px solid var(--border);border-radius:var(--r);padding:7px 10px;font-size:13px;font-family:var(--sans);background:var(--bg);color:var(--text);outline:none">
        <div style="position:relative;width:32px;height:32px;flex-shrink:0">
          <div id="new-type-color-preview" style="width:32px;height:32px;border-radius:var(--r);border:1px solid var(--border);background:#E1F5EE;cursor:pointer"></div>
          <input type="color" id="new-type-color" value="#E1F5EE" oninput="document.getElementById('new-type-color-preview').style.background=this.value" style="position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%">
        </div>
        <button class="btn btn-primary btn-sm" onclick="addType()">新增</button>
      </div>
    </div>

    <!-- 檔期管理 -->
    <div class="form-panel">
      <div class="fp-title">檔期管理</div>
      <p style="font-size:12.5px;color:var(--text2);margin-bottom:1rem;line-height:1.6">新增活動檔期，會在甘特圖最上方以橫幅顯示。</p>
      <div id="campaign-list"></div>
      <div style="display:flex;flex-direction:column;gap:8px;margin-top:12px">
        <input type="text" id="new-camp-name" placeholder="檔期名稱（如：618 購物節）" style="border:1px solid var(--border);border-radius:var(--r);padding:7px 10px;font-size:13px;font-family:var(--sans);background:var(--bg);color:var(--text);outline:none;width:100%">
        <div style="display:flex;gap:8px">
