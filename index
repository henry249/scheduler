let ganttDragState=null; // {postId, startX, origLeft, origWidth, mode:'move'|'resize'}

function renderGantt(){
  document.getElementById('gantt-ym').textContent=ganttYear+'年 '+(ganttMonth+1)+'月';
  const dim=new Date(ganttYear,ganttMonth+1,0).getDate();
  const today=new Date();
  const monthPosts=posts.filter(p=>{
    const ps=new Date(p.date);
    const pe=p.dateEnd?new Date(p.dateEnd):ps;
    const ms=new Date(ganttYear,ganttMonth,1);
    const me=new Date(ganttYear,ganttMonth,dim);
    return ps<=me&&pe>=ms;
  });

  // group by type using customTypes
  const grouped={};
  customTypes.forEach(t=>grouped[t.id]=[]);
  monthPosts.forEach(p=>{if(grouped[p.type]!==undefined)grouped[p.type].push(p)});

  // day headers
  let dayHeaders='';
  for(let d=1;d<=dim;d++){
    const ds=new Date(ganttYear,ganttMonth,d);
    const isSun=ds.getDay()===0,isSat=ds.getDay()===6;
    dayHeaders+=`<div class="gantt-day-hd" style="${isSat||isSun?'color:var(--text3)':''}">${d}</div>`;
  }

  // today line pct
  let todayPct=null;
  if(today.getFullYear()===ganttYear&&today.getMonth()===ganttMonth){
    todayPct=((today.getDate()-0.5)/dim*100).toFixed(2);
  }

  let rows='';
  customTypes.forEach(typeObj=>{
    const typeKey=typeObj.id;
    const col={bg:typeObj.bg,text:typeObj.text};
    const typePosts=grouped[typeKey]||[];
    let bars='';
    typePosts.forEach(p=>{
      const pc=getPostColor(p);
      const ps=new Date(p.date);
      const pe=p.dateEnd?new Date(p.dateEnd):new Date(p.date);
      const ms=new Date(ganttYear,ganttMonth,1);
      const me=new Date(ganttYear,ganttMonth,dim);
      const startD=Math.max(1,Math.floor((Math.max(ps,ms)-ms)/86400000)+1);
      const endD=Math.min(dim,Math.floor((Math.min(pe,me)-ms)/86400000)+1);
      const left=((startD-1)/dim*100).toFixed(3);
      const width=((endD-startD+1)/dim*100).toFixed(3);
      const hasRange=!!p.dateEnd;
      bars+=`<div class="gantt-bar" data-id="${p.id}"
        style="left:${left}%;width:${width}%;background:${pc.bg};color:${pc.text};border:1px solid ${pc.text}30;cursor:grab"
        title="${esc(p.title)}"
        onmousedown="ganttDragStart(event,${p.id},'move')"
        onclick="openModal(null,${p.id})">
        ${esc(p.title)}
        ${hasRange?`<div class="gantt-resize-handle" onmousedown="ganttDragStart(event,${p.id},'resize')"></div>`:''}
      </div>`;
    });
    const todayLine=todayPct!==null?`<div class="gantt-today-line" style="left:${todayPct}%"></div>`:'';
    rows+=`<div class="gantt-row" data-type="${typeKey}">
      <div class="gantt-row-label" style="border-left:3px solid ${col.text};padding-left:10px">${esc(typeObj.name)}</div>
      <div class="gantt-track" data-type="${typeKey}" onclick="ganttTrackClick(event,'${typeKey}')">${bars}${todayLine}</div>
    </div>`;
  });

  document.getElementById('gantt-inner').innerHTML=`
    <div class="gantt-head">
      <div class="gantt-label-col">內容類型</div>
      <div class="gantt-days-head">${dayHeaders}</div>
    </div>${rows}`;
  initGanttDrag();
}

function initGanttDrag(){
  document.removeEventListener('mousemove',ganttMouseMove);
  document.removeEventListener('mouseup',ganttMouseUp);
  document.addEventListener('mousemove',ganttMouseMove);
  document.addEventListener('mouseup',ganttMouseUp);
}

function ganttTrackClick(e,typeKey){
  // only trigger on empty track, not on bars
  if(e.target.classList.contains('gantt-bar')||e.target.classList.contains('gantt-resize-handle')||e.target.classList.contains('gantt-today-line'))return;
  if(ganttDragState)return; // was a drag
  const track=e.currentTarget;
  const rect=track.getBoundingClientRect();
  const dim=new Date(ganttYear,ganttMonth+1,0).getDate();
  const clickX=e.clientX-rect.left;
  const day=Math.min(dim,Math.max(1,Math.floor(clickX/rect.width*dim)+1));
  const ds=ganttYear+'-'+String(ganttMonth+1).padStart(2,'0')+'-'+String(day).padStart(2,'0');
  openQA(ds);
  // pre-select the type
  setTimeout(()=>{const sel=document.getElementById('qa-type');if(sel)sel.value=typeKey;},50);
}

function ganttDragStart(e,postId,mode){
  if(mode==='resize')e.stopPropagation();
  e.preventDefault();
  const track=e.currentTarget.closest('.gantt-track')||e.currentTarget.parentElement;
  const trackRect=track?track.getBoundingClientRect():{width:1,left:0};
  ganttDragState={postId,mode,startX:e.clientX,trackWidth:trackRect.width,trackLeft:trackRect.left};
  document.body.style.userSelect='none';
  const bar=document.querySelector(`.gantt-bar[data-id="${postId}"]`);
  if(bar)bar.style.opacity='.6';
}

function ganttMouseMove(e){
  if(!ganttDragState)return;
  const {postId,mode,startX,trackWidth,trackLeft}=ganttDragState;
  const dim=new Date(ganttYear,ganttMonth+1,0).getDate();
  const dx=e.clientX-startX;
  const dayPx=trackWidth/dim;
  const daysDelta=Math.round(dx/dayPx);
  if(daysDelta===0)return;
  const p=posts.find(x=>x.id===postId);if(!p)return;

  if(mode==='move'){
    const origStart=new Date(p._dragDate||p.date);
    const newStart=new Date(origStart.getTime()+daysDelta*86400000);
    // highlight bar
    const bar=document.querySelector(`.gantt-bar[data-id="${postId}"]`);
    if(bar){
      const newLeft=((newStart.getDate()-1)/dim*100).toFixed(3);
      bar.style.left=newLeft+'%';
    }
  } else if(mode==='resize'&&p.dateEnd){
    const origEnd=new Date(p._dragEnd||p.dateEnd);
    const newEnd=new Date(origEnd.getTime()+daysDelta*86400000);
    const bar=document.querySelector(`.gantt-bar[data-id="${postId}"]`);
    if(bar){
      const startD=new Date(p.date).getDate();
      const endD=Math.max(new Date(p.date).getDate(),newEnd.getDate());
      const newW=((endD-startD+1)/dim*100).toFixed(3);
      bar.style.width=newW+'%';
    }
  }
}

function ganttMouseUp(e){
  if(!ganttDragState)return;
  const {postId,mode,startX,trackWidth}=ganttDragState;
  const dim=new Date(ganttYear,ganttMonth+1,0).getDate();
  const dx=e.clientX-startX;
  const dayPx=trackWidth/dim;
  const daysDelta=Math.round(dx/dayPx);
  ganttDragState=null;
  document.body.style.userSelect='';

  if(daysDelta===0){
    const bar=document.querySelector(`.gantt-bar[data-id="${postId}"]`);
    if(bar)bar.style.opacity='';
    return;
  }

  const p=posts.find(x=>x.id===postId);if(!p)return;
  if(mode==='move'){
    const newStart=new Date(new Date(p.date).getTime()+daysDelta*86400000);
    if(p.dateEnd){
      const newEnd=new Date(new Date(p.dateEnd).getTime()+daysDelta*86400000);
      p.dateEnd=newEnd.toISOString().slice(0,10);
    }
    p.date=newStart.toISOString().slice(0,10);
    toast('已移至 '+p.date);
  } else if(mode==='resize'&&p.dateEnd){
    const newEnd=new Date(new Date(p.dateEnd).getTime()+daysDelta*86400000);
    if(newEnd>=new Date(p.date)){
      p.dateEnd=newEnd.toISOString().slice(0,10);
      toast('區間已調整至 '+p.dateEnd);
    }
  }
  posts.sort((a,b)=>(a.date+a.time).localeCompare(b.date+b.time));
  save();renderGantt();
}

